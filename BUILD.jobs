# ============================================================================

def src_import():
    component = params["component"]
    if component == "registry":
        project, ref = REGISTRY
    elif component == "workhorse":
        return gitlab_import()
    else:
        project, ref, _ = SATELLITES[component]
    return imp(fetcher = GITLABFETCHER, params = {"project": project, "ref": ref})

def gitlab_import():
    return imp(fetcher = GITLABFETCHER, params = {"project": "gitlab-org/gitlab-foss", "ref": GITLAB})

def apk_import(name, ver, repo, shas):
    return imp(fetcher = ALPINEAPK, params = {
        "branch": "v3.22", "repo": repo, "arch": APK_ARCH[platform],
        "name": name, "version": ver, "sha256": shas[APK_ARCH[platform]],
    })

def plugins():
    component = params["component"]
    if component not in COMPONENTS and component not in ["gitaly", "rails", "webservice"]:
        fail("unknown component %r (want one of %s)" % (component, ", ".join(sorted(COMPONENTS.keys()) + ["gitaly", "rails", "webservice"])))

    # The monolith: the bundler plugin reads the upstream Gemfile.lock out of
    # the gitlab-foss tree at pin time; webservice adds the node plugin over
    # yarn.lock for the asset build.
    if component == "rails":
        return struct(
            plugins = {"bundler": imp(fetcher = BUNDLERPLUGIN, params = {})},
            deps = {"gitlab": gitlab_import()},
        )
    if component == "webservice":
        return struct(
            plugins = {
                "bundler": imp(fetcher = BUNDLERPLUGIN, params = {}),
                "node": imp(fetcher = NODEPLUGIN, params = {}),
            },
            deps = {"gitlab": gitlab_import()},
        )

    # The component source is a resolution dep (its go.sum is read at pin
    # time) AND a build input below — identical definition, one graph node.
    # workhorse builds out of the gitlab-foss tree itself.
    if component == "workhorse":
        deps = {"gitlab": gitlab_import()}
    else:
        deps = {"src": src_import()}
        if component in SATELLITES:
            deps["gitlab"] = gitlab_import()
    return struct(plugins = {"go": imp(fetcher = GOPLUGIN, params = {})}, deps = deps)

def assert_satellite_pin(component):
    # Self-checking satellite pin: the GitLab release declares each
    # component's version; a drifted pin fails here with the expected value.
    if component in SATELLITES:
        project, ref, vfile = SATELLITES[component]
        want = str(deps["gitlab"].read(vfile)).strip()
        if ref[1:] != want:
            fail("%s pin %s drifted: gitlab-foss %s declares %s = %s — update SATELLITES[%r]" %
                 (component, ref, GITLAB, vfile, want, component))

def toolchain_import():
    goarch = GOARCH[platform]
    return imp(fetcher = "tarball+https", params = {
        "url": "https://go.dev/dl/go1.26.4.linux-" + goarch + ".tar.gz",
        "sha256": GO_SHA[goarch],
    })

def mod_inputs(go_sum):
    # One gomod import per module in the component's go.sum (read from the
    # resolution dep — the tree itself is only fetched once, shared with the
    # build input).
    mods = plugins["go"](go_sum = go_sum)
    inputs = {}
    copies = []
    for m in mods:
        name = "mod_" + m["path"].replace("/", "_").replace(".", "_").replace("-", "_")
        inputs[name] = m["input"]
        copies.append('cp -dr "$(jq -r .' + name + ' <<<"$JOBS_DEPS")/." "$GOMODCACHE/"')
    return inputs, copies

GO_ENV = """
set -e
# Many-input builds: the runner may carry the deps map only in a file
# (JOBS_DEPS_FILE) — load it as an UNEXPORTED shell var (herestrings do not
# traverse execve, so size is safe).
[ -n "${JOBS_DEPS:-}" ] || JOBS_DEPS=$(cat "$JOBS_DEPS_FILE")
export GOROOT=/build/goroot
mkdir -p "$GOROOT" "$out/bin"
cp -dr "$(jq -r .toolchain <<<"$JOBS_DEPS")/go/." "$GOROOT/"
export PATH="$GOROOT/bin:$PATH"
export GOMODCACHE=/build/gomodcache GOCACHE=/go-build-cache GOPATH=/build/gopath
export GOPROXY=off GOSUMDB=off GOFLAGS=-mod=mod GOTOOLCHAIN=local CGO_ENABLED=0
mkdir -p "$GOMODCACHE/cache/download"
"""

def build():
    component = params["component"]
    if component == "gitaly":
        return gitaly_build()
    if component == "rails":
        return rails_build(False)
    if component == "webservice":
        return rails_build(True)

    bins, smoke, entry_bin, subdir = COMPONENTS[component]
    assert_satellite_pin(component)

    src_dep = "gitlab" if component == "workhorse" else "src"
    sum_path = (subdir + "/" if subdir else "") + "go.sum"
    inputs, copies = mod_inputs(deps[src_dep].read(sum_path))
    inputs["toolchain"] = toolchain_import()
    inputs["src"] = src_import()

    # Runtime deps must also be declared as inputs (pin-stage validation);
    # the build script never touches them.
    runtime_deps = []
    if component == "workhorse":
        for (name, ver, repo, shas) in WORKHORSE_RUNTIME_APKS:
            i = apk_import(name, ver, repo, shas)
            inputs["rt_" + name.replace("-", "_").replace(".", "_")] = i
            runtime_deps.append(i)

    build_lines = "\n".join(['go build -o "$out/bin/%s" %s' % (b, p) for b, p in bins])
    entrypoint = '{"command": "bin/%s", "args": [], "env": {}}' % entry_bin

    cd_line = 'cd "$SRCTREE' + ("/" + subdir if subdir else "") + '"'
    tail = """
chmod -R u+w "$GOROOT" "$GOMODCACHE" 2>/dev/null || true
SRCTREE=/build/src
mkdir -p "$SRCTREE"
cp -dr "$(jq -r .src <<<"$JOBS_DEPS")/." "$SRCTREE/"
chmod -R u+w "$SRCTREE"
""" + cd_line + "\n" + build_lines + "\n" + smoke + "\n" + "cat > \"$out/JOBS.entrypoint\" <<'EOF'\n" + entrypoint + "\nEOF\n"

    return struct(
        name = "gitlab-" + component,
        inputs = inputs,
        env = {},
        script = GO_ENV + "\n".join(copies) + tail,
        runtime_deps = runtime_deps,
        resources = struct(cpu = "2000m", memory = "4Gi"),
        # Persistent per-component Go build cache (platform is auto-appended
        # by the runner).
        caches = {"/go-build-cache": "gitlab-build-" + component + "-go1.26.4"},
    )

def mk_var(mk, name):
    # Parse `NAME ?= value` out of gitaly's Makefile.
    for line in mk.splitlines():
        if line.startswith(name):
            rest = line[len(name):].strip()
            if rest.startswith("?=") or rest.startswith(":="):
                return rest[2:].strip()
    fail("gitaly Makefile: %s not found" % name)

# The meson options gitaly's Makefile sets for its bundled git builds.
GIT_MESON_OPTIONS = " ".join([
    "-Dprefix=/usr/local",
    "-Dbuildtype=debugoptimized",
    "-Dcurl=enabled",
    "-Dexpat=disabled",
    "-Dgettext=disabled",
    "-Dgitweb=disabled",
    "-Diconv=enabled",
    "-Dpcre2=enabled",
    "-Dperl=disabled",
    "-Dpython=disabled",
    "-Drust=disabled",
    "-Dtests=false",
    "-Dwrap_mode=nofallback",
    "-Dsha1_unsafe_backend=openssl",
])

GIT_EXECUTABLES = ["git", "git-remote-http", "git-http-backend"]

def gitaly_build():
    assert_satellite_pin("gitaly")

    mk = str(deps["src"].read("Makefile"))
    git_refs = {
        "master": mk_var(mk, "GIT_VERSION_MASTER"),
        "prev": mk_var(mk, "GIT_VERSION_PREV"),
    }
    module = str(deps["src"].read("go.mod")).splitlines()[0].split(" ")[1].strip()
    version = str(deps["src"].read("VERSION")).strip()

    inputs, copies = mod_inputs(deps["src"].read("go.sum"))
    inputs["toolchain"] = toolchain_import()
    inputs["src"] = src_import()

    stage = []
    for (name, ver, repo, shas) in GITALY_BUILD_APKS:
        key = "apk_" + name.replace("-", "_").replace("+", "_").replace(".", "_")
        inputs[key] = apk_import(name, ver, repo, shas)
        stage.append('cp -dr "$(jq -r .%s <<<"$JOBS_DEPS")/." /' % key)

    runtime_deps = []
    for (name, ver, repo, shas) in GITALY_RUNTIME_APKS:
        runtime_deps.append(apk_import(name, ver, repo, shas))

    git_builds = []
    for suffix in ["master", "prev"]:
        inputs["gitsrc_" + suffix] = imp(fetcher = GITLABFETCHER, params = {
            "project": "gitlab-org/git", "ref": git_refs[suffix],
        })
        git_builds.append("""
GITDIR=/build/git-%s
mkdir -p "$GITDIR"
cp -dr "$(jq -r .gitsrc_%s <<<"$JOBS_DEPS")/." "$GITDIR/"
chmod -R u+w "$GITDIR"
meson setup "$GITDIR/build" "$GITDIR" %s
meson compile -C "$GITDIR/build" %s
""" % (suffix, suffix, GIT_MESON_OPTIONS, " ".join([e + ":executable" for e in GIT_EXECUTABLES])) + "\n".join([
            'cp "$GITDIR/build/%s" "$SRCTREE/_build/bin/gitaly-%s-%s"' % (e, e, suffix)
            for e in GIT_EXECUTABLES
        ]))

    # Auxiliary binaries embedded into gitaly (packed_binaries.go), then the
    # installed binaries. gitaly + praefect get the server build tags.
    aux = ["gitaly-hooks", "gitaly-ssh", "gitaly-lfs-smudge", "gitaly-gpg"]
    installed = ["gitaly-wrapper", "gitaly-backup", "gitaly-blackbox", "gitaly-debug"]
    ldflags = "-X %s/internal/version.version=%s" % (module, version)
    go_builds = ["go build -ldflags '%s' -o _build/bin/%s ./cmd/%s" % (ldflags, b, b) for b in aux]
    go_builds += ["go build -tags continuous_profiler_stackdriver -ldflags '%s' -o \"$out/bin/%s\" ./cmd/%s" % (ldflags, b, b) for b in ["gitaly", "praefect"]]
    go_builds += ["go build -ldflags '%s' -o \"$out/bin/%s\" ./cmd/%s" % (ldflags, b, b) for b in installed]

    script = GO_ENV + """
# 1. Stage the Alpine gcc/meson userland into the sandbox root.
""" + "\n".join(stage) + """
for a in $(/bin/busybox --list); do ln -sf /bin/busybox "/bin/$a" 2>/dev/null || true; done
ln -sf /bin/busybox /usr/bin/env 2>/dev/null || true
export PATH="/usr/bin:/bin:$PATH"
export HOME=/build
gcc --version | head -1
meson --version

# 2. Go module cache.
""" + "\n".join(copies) + """
chmod -R u+w "$GOROOT" "$GOMODCACHE" 2>/dev/null || true

# 3. Gitaly source.
SRCTREE=/build/src
mkdir -p "$SRCTREE"
cp -dr "$(jq -r .src <<<"$JOBS_DEPS")/." "$SRCTREE/"
chmod -R u+w "$SRCTREE"
mkdir -p "$SRCTREE/_build/bin"

# 4. Bundled git: meson-build both pinned versions, stage as the embed set.
""" + "\n".join(git_builds) + """

# 5. Go binaries: aux (embedded) first, then gitaly/praefect (+tags) and the
#    rest of the installed executables.
cd "$SRCTREE"
""" + "\n".join(go_builds) + """

# 6. Smoke: version prints + the bundled-git embed actually unpacks.
"$out/bin/gitaly" -version
"$out/bin/praefect" -version

cat > "$out/JOBS.entrypoint" <<'EOF'
{"command": "bin/gitaly", "args": [], "env": {}}
EOF
"""

    return struct(
        name = "gitlab-gitaly",
        inputs = inputs,
        env = {},
        script = script,
        runtime_deps = runtime_deps,
        resources = struct(cpu = "4000m", memory = "6Gi"),
        caches = {"/go-build-cache": "gitlab-build-gitaly-go1.26.4"},
    )

def rails_build(with_assets):
    # Exact-Ruby pin, self-checking against the tree.
    want_ruby = str(deps["gitlab"].read(".ruby-version")).strip()
    if want_ruby != RUBY_VERSION:
        fail("ruby pin %s drifted: gitlab-foss %s declares .ruby-version = %s — update RUBY_VERSION/RUBY_SHA256" %
             (RUBY_VERSION, GITLAB, want_ruby))

    # The bundler plugin reads the UPSTREAM lock and returns {packages, lock}:
    # the fetch set and the build-time lock derived for our platforms. GitLab
    # has no git-sourced gems (upstream policy) and 29 in-tree path: gems that
    # resolve offline for free.
    # No transform: GitLab has no git gems and needs no lock rewrite — but
    # its lock also carries NO musl platform rows, so the install below runs
    # NON-frozen: the cache holds exactly the locked versions (musl variants
    # where published, ruby/source otherwise), which pins resolution to the
    # upstream solution while letting bundler add the musl rows itself.
    packages = plugins["bundler"](
        gemfile_lock = str(deps["gitlab"].read("Gemfile.lock")),
        platforms = ["ruby", GEM_PLATFORM[platform]],
    )

    inputs = {
        "src": gitlab_import(),
        "toolchain": toolchain_import(),
        "rubysrc": imp(fetcher = "tarball+https", params = {
            "url": "https://ftp.ruby-lang.org/pub/ruby/3.3/ruby-" + RUBY_VERSION + ".tar.gz",
            "sha256": RUBY_SHA256,
            "strip": 1,
        }),
        "bundlergem": imp(fetcher = RUBYGEMS, params = {"name": "bundler", "version": BUNDLER_VERSION}),
    }

    stage = []
    for (name, ver, repo, shas) in RAILS_BUILD_APKS:
        key = "apk_" + name.replace("-", "_").replace("+", "_").replace(".", "_")
        inputs[key] = apk_import(name, ver, repo, shas)
        stage.append('cp -dr "$(jq -r .%s <<<"$JOBS_DEPS")/." /' % key)

    runtime_deps = []
    for (name, ver, repo, shas) in RAILS_RUNTIME_APKS:
        i = apk_import(name, ver, repo, shas)
        inputs["rt_" + name.replace("-", "_").replace(".", "_")] = i
        runtime_deps.append(i)

    gem_copies = []
    lock_text = str(deps["gitlab"].read("Gemfile.lock"))
    for name in MUSL_PRECOMPILED:
        k = "gem_musl_" + name.replace("-", "_")
        inputs[k] = imp(fetcher = RUBYGEMS, params = {
            "name": name,
            "version": lock_version(lock_text, name),
            "platform": GEM_PLATFORM[platform],
        })
        gem_copies.append('cp "$(jq -r .%s <<<"$JOBS_DEPS")"/*.gem "$APP/vendor/cache/" 2>/dev/null || true' % k)
    assets_stage = ""
    if with_assets:
        narch = NODEARCH[platform]
        node_url, node_sha = NODE[narch]
        inputs["node"] = imp(fetcher = "tarball+https", params = {"url": node_url, "sha256": node_sha, "strip": 1})
        inputs["yarn"] = imp(fetcher = "tarball+https", params = {"url": YARN[0], "sha256": YARN[1], "strip": 1})
        npms = plugins["node"](yarn_lock = deps["gitlab"].read("yarn.lock"))
        mirror_adds = []
        for i, n in enumerate(npms):
            k = "npm_%d" % i
            inputs[k] = n["input"]
            mirror_adds.append('cp "$(jq -r .%s <<<"$JOBS_DEPS")"/*.tgz /build/yarn-mirror/' % k)
        assets_stage = """
# 8. Assets: musl Node + yarn classic + offline mirror, then the CNG-style
#    no-DB asset compile. node_modules snapshot keyed by yarn.lock hash.
mkdir -p /build/node /build/yarn /build/yarn-mirror
cp -dr "$(jq -r .node <<<"$JOBS_DEPS")/." /build/node/
cp -dr "$(jq -r .yarn <<<"$JOBS_DEPS")/." /build/yarn/
chmod -R u+w /build/node /build/yarn
export PATH="/build/node/bin:/build/yarn/bin:$PATH"
# node-gyp (native optional deps, e.g. the tree-sitter family pulled in by
# @swagger-api/apidom's yaml parsers) must never download node headers — the
# sandbox is net=none, so the fetch fails with EAI_AGAIN and the modules stay
# unbuilt (which hard-fails assets:compile on arches without shipped
# prebuilds, e.g. arm64-musl). The node tarball ships include/node; point
# gyp at it so native rebuilds are hermetic.
export npm_config_nodedir=/build/node
node --version
yarn --version
""" + "\n".join(mirror_adds) + """
cd "$APP"
# Hermetic name resolution: the sandbox ships no /etc/hosts or resolv.conf,
# so any resolver path blocks FOREVER on a UDP socket nothing will answer —
# pg 1.6 resolves database.yml's host itself (Ruby-side getaddrinfo) before
# connecting, which froze rails boot inside gitlab:js_routes at ~zero CPU.
# A minimal hosts file answers localhost instantly and an empty resolv.conf
# makes any other lookup fail fast instead of hanging.
mkdir -p /etc
printf "127.0.0.1 localhost\n::1 localhost\n" > /etc/hosts || true
: > /etc/resolv.conf || true
cat > .yarnrc <<'YARNRC'
yarn-offline-mirror "/build/yarn-mirror"
YARNRC
YARNHASH=$(sha256sum yarn.lock | cut -c1-16)
if [ -d "/gem-cache/nm-$YARNHASH/node_modules" ]; then
  cp -dr "/gem-cache/nm-$YARNHASH/node_modules" .
else
  yarn install --offline --frozen-lockfile --ignore-engines
  rm -rf "/gem-cache/nm-$YARNHASH"
  mkdir -p "/gem-cache/nm-$YARNHASH"
  cp -dr node_modules "/gem-cache/nm-$YARNHASH/"
fi
# The env boot insists on real config files; stage the shipped examples
# (the CNG assets image does the same).
# Minimal CE database config (the shipped .postgresql template carries
# EE-only databases — geo, embedding — that CE's validator rejects; no DB
# is contacted with USE_DB=false).
cat > config/database.yml <<'DBYML'
production:
  main:
    adapter: postgresql
    encoding: unicode
    database: gitlabhq_production
    username: git
    host: localhost
DBYML
cp config/gitlab.yml.example config/gitlab.yml
# Gitlab.revision shells out to git unless a REVISION file exists (CNG
# ships one; archives carry no .git).
echo "GITLAB_REF_PLACEHOLDER" > REVISION
mkdir -p /tmp/prometheus_multiproc
export prometheus_multiproc_dir=/tmp/prometheus_multiproc
export RAILS_ENV=production NODE_ENV=production USE_DB=false SKIP_STORAGE_VALIDATION=true
export SECRET_KEY_BASE=jobsbuilddummysecretkeybase0000000000000000000000000000000000000
# Two DISTINCT memory walls, measured: webpack's main node process needs
# >3584MB of JS HEAP (V8 aborts SIGABRT "Reached heap limit" below that,
# regardless of the cgroup budget), and the whole cgroup must also fit the
# heap PLUS the terser workers (scale with host cores; ~12.8Gi total peak
# observed on 20-core gx10 even with a 3584 heap) — so: 6144 heap, and the
# build's declared memory sized per arch below.
export NODE_OPTIONS="--max-old-space-size=6144"
bundle exec rake gitlab:assets:compile > /build/assets.log 2>&1 || {
  { echo "===== gitlab:assets:compile FAILED; rake aborted section:"; grep -B2 -A40 "rake aborted" /build/assets.log | head -80; echo "===== assets.log tail:"; tail -60 /build/assets.log; } >&2
  exit 1
}
tail -5 /build/assets.log
test -f public/assets/webpack/manifest.json
unset NODE_OPTIONS SECRET_KEY_BASE USE_DB SKIP_STORAGE_VALIDATION NODE_ENV
"""

    gi = 0
    for g in packages:
        k = "gem_%d" % gi
        gi += 1
        inputs[k] = g["input"]
        gem_copies.append('cp "$(jq -r .%s <<<"$JOBS_DEPS")"/*.gem "$APP/vendor/cache/" 2>/dev/null || true' % k)

    script = ("""
set -e
# Many-input builds: the runner may carry the deps map only in a file
# (JOBS_DEPS_FILE) — load it as an UNEXPORTED shell var (herestrings do not
# traverse execve, so size is safe).
[ -n "${JOBS_DEPS:-}" ] || JOBS_DEPS=$(cat "$JOBS_DEPS_FILE")

# 1. Alpine gcc/g++ userland + the -dev closure of every source-built gem.
""" + "\n".join(stage) + """
for a in $(/bin/busybox --list); do ln -sf /bin/busybox "/bin/$a" 2>/dev/null || true; done
ln -sf /bin/busybox /usr/bin/env 2>/dev/null || true
export PATH="/usr/bin:/bin:$PATH"
export HOME=/build

# Go toolchain (the devfile gem's native ext builds a Go c-shared library).
export GOROOT=/build/goroot
mkdir -p "$GOROOT"
cp -dr "$(jq -r .toolchain <<<"$JOBS_DEPS")/go/." "$GOROOT/"
chmod -R u+w "$GOROOT" 2>/dev/null || true
export PATH="$GOROOT/bin:$PATH" GOCACHE=/build/gocache GOTOOLCHAIN=local GOPROXY=off GOSUMDB=off

# 2. Ruby RUBY_VERSION_PLACEHOLDER from source (static, no docs, no YJIT),
#    prefix /usr/local/ruby. Snapshot-cached — a recipe iteration reuses the
#    compiled prefix.
if [ -f "/gem-cache/ruby-RUBY_VERSION_PLACEHOLDER.tar" ]; then
  (cd / && tar xf "/gem-cache/ruby-RUBY_VERSION_PLACEHOLDER.tar")
else
  mkdir -p /build/ruby-src
  cp -dr "$(jq -r .rubysrc <<<"$JOBS_DEPS")/." /build/ruby-src/
  chmod -R u+w /build/ruby-src
  cd /build/ruby-src
  ./configure --prefix=/usr/local/ruby --disable-shared --disable-install-doc --with-baseruby=/usr/bin/ruby >/build/ruby-configure.log 2>&1 || { tail -50 /build/ruby-configure.log >&2; exit 1; }
  make -j"$(nproc)" >/build/ruby-make.log 2>&1 || { tail -50 /build/ruby-make.log >&2; exit 1; }
  make install >/dev/null
  tar cf "/gem-cache/ruby-RUBY_VERSION_PLACEHOLDER.tar" /usr/local/ruby 2>/dev/null || true
fi
export PATH="/usr/local/ruby/bin:$PATH"
ruby --version

# 3. Bundler at the lock's BUNDLED WITH version.
gem install --local --no-document "$(jq -r .bundlergem <<<"$JOBS_DEPS")"/*.gem
bundle --version

# 4. Assemble the app: gitlab-foss source + the derived build-time lock.
APP=/build/app
mkdir -p "$APP"
cp -dr "$(jq -r .src <<<"$JOBS_DEPS")/." "$APP/"
chmod -R u+w "$APP"

# 5. Offline gem install from the staged .gem cache. Precompiled -linux-musl
#    monsters (grpc, protobuf, re2, ffi, nokogiri, glfm-markdown,
#    prometheus-client-mmap) unpack; the rest compile with gcc/g++ against
#    the staged -dev closures.
mkdir -p "$APP/vendor/cache"
""" + "\n".join(gem_copies) + """
cd "$APP"
export BUNDLE_FROZEN=false BUNDLE_PATH=vendor/bundle BUNDLE_DISABLE_SHARED_GEMS=true
export BUNDLE_WITHOUT=development:test
export BUNDLE_BUILD__GPGME=--use-system-libraries
LOCKHASH=$(sha256sum Gemfile.lock | cut -c1-16)
# The upstream lock has no musl platform rows and a lock-following install
# never re-resolves platforms — drop it and let bundler resolve against the
# cache (which holds exactly the locked versions, musl variants included),
# writing a fresh platform-correct lock.
rm -f Gemfile.lock
if [ -f "/gem-cache/bundle-$LOCKHASH.tar" ]; then
  tar xf "/gem-cache/bundle-$LOCKHASH.tar"
else
  bundle install --local || {
    echo "===== bundle install FAILED; native build logs with real errors:" >&2
    for f in vendor/bundle/ruby/*/extensions/*/*/*/gem_make.out vendor/bundle/ruby/*/gems/*/ext/*/mkmf.log; do
      [ -f "$f" ] || continue
      if grep -qE "Error [0-9]+ *$|error:|fatal error|undefined reference" "$f"; then
        { echo "===== $f"; tail -n 60 "$f"; } >&2
      fi
    done
    exit 1
  }
  tar cf "/gem-cache/bundle-$LOCKHASH.tar" vendor/bundle
fi

# 6. Native smoke: load every heavyweight extension.
bundle exec ruby -e 'l = %w[grpc google/protobuf re2 pg gpgme charlock_holmes magic oj bcrypt nokogiri ffi gitlab-glfm-markdown prometheus/client]; l.each { |r| require r }; STDERR.puts "GITLAB-RAILS-NATIVES-OK ruby=#{RUBY_VERSION}"'

ASSETS_STAGE_PLACEHOLDER
# 7. Deployable app tree + env-driven entrypoints (config is a deploy
#    concern: DATABASE_URL/REDIS_URL/GITLAB_* env). Runtime closure staged
#    from /jobs/store by the scripts, fizzy-style.
mkdir -p "$out"
cp -dr "$APP"/. "$out"/
rm -rf "$out/vendor/cache" "$out/tmp/cache" "$out/node_modules"
# bin/web boots puma -C config/puma.rb; ship the example as the default
# (deployments override via mounted config).
[ -f "$out/config/puma.rb" ] || cp "$out/config/puma.rb.example" "$out/config/puma.rb" 2>/dev/null || true
mkdir -p "$out/bin"
cat > "$out/bin/jobs-stage-runtime" <<'EOF'
#!/jobs/shell/bin/bash
set -e
self="$PWD"
for d in /jobs/store/*/; do
  d="${d%/}"
  [ "$d" = "$self" ] && continue
  cp -dr "$d"/. / 2>/dev/null || true
done
for a in $(/bin/busybox --list 2>/dev/null); do ln -sf /bin/busybox "/bin/$a" 2>/dev/null || true; done
ln -sf /bin/busybox /usr/bin/env 2>/dev/null || true
EOF
cat > "$out/bin/web" <<'EOF'
#!/jobs/shell/bin/bash
set -e
"$PWD/bin/jobs-stage-runtime"
export PATH="/usr/local/ruby/bin:/usr/bin:/bin:$PATH" HOME=/tmp
export RAILS_ENV=production BUNDLE_PATH=vendor/bundle BUNDLE_FROZEN=false BUNDLE_WITHOUT=development:test
cd "$PWD"
exec bundle exec puma -C config/puma.rb -b "tcp://0.0.0.0:${PORT:-8080}"
EOF
cat > "$out/bin/sidekiq" <<'EOF'
#!/jobs/shell/bin/bash
set -e
"$PWD/bin/jobs-stage-runtime"
export PATH="/usr/local/ruby/bin:/usr/bin:/bin:$PATH" HOME=/tmp
export RAILS_ENV=production BUNDLE_PATH=vendor/bundle BUNDLE_FROZEN=false BUNDLE_WITHOUT=development:test
cd "$PWD"
exec bundle exec sidekiq
EOF
chmod +x "$out/bin/jobs-stage-runtime" "$out/bin/web" "$out/bin/sidekiq"
cat > "$out/JOBS.entrypoint" <<'EOF'
{"command": "bin/web", "args": [], "env": {}}
EOF
""").replace("RUBY_VERSION_PLACEHOLDER", RUBY_VERSION).replace("GITLAB_REF_PLACEHOLDER", GITLAB).replace("ASSETS_STAGE_PLACEHOLDER", assets_stage)

    # Ruby itself ships inside the runtime closure? No — ruby lives in the
    # artifact-independent /usr/local/ruby prefix built here; the app tree
    # can't carry it (absolute-prefix rbconfig). Ship the prefix as part of
    # the output instead, staged back to /usr/local/ruby by the entrypoints.
    script = script + """
mkdir -p "$out/jobs-ruby"
cp -dr /usr/local/ruby/. "$out/jobs-ruby/"
"""
    script = script.replace('"$PWD/bin/jobs-stage-runtime"\n', '"$PWD/bin/jobs-stage-runtime"\nmkdir -p /usr/local/ruby && cp -dr "$PWD/jobs-ruby/." /usr/local/ruby/ 2>/dev/null || true\n')

    name = "gitlab-webservice" if with_assets else "gitlab-rails"
    return struct(
        name = name,
        inputs = inputs,
        env = {},
        script = script,
        runtime_deps = runtime_deps,
        # webservice's webpack pass peaked >8Gi under an ENFORCED memory.max
        # (both arches OOM'd at exactly the old 8Gi cap once cluster cgroup
        # limits became real). arm64 (gx10, 125Gi host) gets room; amd64
        # (mac-mini, 15Gi host, 10Gi advertised) gets the most that fits —
        # paired with the CNG-standard 3584 node heap below.
        resources = struct(cpu = "4000m", memory = ({"linux/amd64": "9Gi", "linux/arm64": "24Gi"}[platform] if with_assets else "8Gi")),
        caches = {"/gem-cache": name + "-cache"},
    )
