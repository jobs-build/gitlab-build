# BUILD.jobs — hermetic JOBS builds of the Cloud Native GitLab (CE) components.
#
# One component per invocation, selected by --param component=:
#
#   jobs remote-build --source-dir . --param component=shell      # gitlab-shell
#   jobs remote-build --source-dir . --param component=pages      # gitlab-pages
#   jobs remote-build --source-dir . --param component=kas        # gitlab-kas
#   jobs remote-build --source-dir . --param component=registry   # container-registry
#   jobs remote-build --source-dir . --param component=workhorse  # gitlab-workhorse
#   jobs remote-build --source-dir . --param component=gitaly     # gitaly + bundled git
#
# Design: draganm/jobs docs/superpowers/specs/2026-07-11-gitlab-cng-build-design.md.
# Satellite pins below are STATIC but SELF-CHECKING: at pin time the recipe
# reads the master gitlab-foss tree's VERSION files (a resolution dep) and
# fails loudly if a pin drifts from what the GitLab release declares. Bump
# procedure: update GITLAB, run any satellite build, copy the expected
# versions out of the assertion failures into SATELLITES.
#
# gitaly bundles git: TWO git versions (master + prev, commit refs parsed out
# of gitaly's own Makefile at pin time — self-deriving, nothing to bump here)
# are meson-built from the gitlab-org/git mirror and embedded into the gitaly
# binary via its go:embed of _build/bin/gitaly-git-* (packed_binaries.go).

GITLAB = "v19.1.2"  # gitlab-org/gitlab-foss stable CE tag — the master pin

# component -> (project, ref, VERSION file in the gitlab-foss tree)
SATELLITES = {
    "shell": ("gitlab-org/gitlab-shell", "v14.54.0", "GITLAB_SHELL_VERSION"),
    "pages": ("gitlab-org/gitlab-pages", "v19.1.2", "GITLAB_PAGES_VERSION"),
    "kas": ("gitlab-org/cluster-integration/gitlab-agent", "v19.1.2", "GITLAB_KAS_VERSION"),
    "gitaly": ("gitlab-org/gitaly", "v19.1.2", "GITALY_SERVER_VERSION"),
}

# container-registry releases independently of GitLab — own pin, no assertion.
REGISTRY = ("gitlab-org/container-registry", "v4.40.2-gitlab")

# Plain-Go components: (list of (binary, go package), smoke command,
# entrypoint binary, subdir within the source tree). gitaly has its own build
# path below.
COMPONENTS = {
    "shell": (
        [
            ("gitlab-shell", "./cmd/gitlab-shell"),
            ("gitlab-sshd", "./cmd/gitlab-sshd"),
            ("gitlab-shell-check", "./cmd/gitlab-shell-check"),
            ("gitlab-shell-authorized-keys-check", "./cmd/gitlab-shell-authorized-keys-check"),
            ("gitlab-shell-authorized-principals-check", "./cmd/gitlab-shell-authorized-principals-check"),
        ],
        '"$out/bin/gitlab-shell" -version',
        "gitlab-sshd",
        "",
    ),
    "pages": ([("gitlab-pages", ".")], '"$out/bin/gitlab-pages" -version', "gitlab-pages", ""),
    "kas": ([("kas", "./cmd/kas")], '"$out/bin/kas" --version', "kas", ""),
    "registry": ([("registry", "./cmd/registry")], '"$out/bin/registry" help >/dev/null', "registry", ""),
    "workhorse": (
        [
            ("gitlab-workhorse", "./cmd/gitlab-workhorse"),
            ("gitlab-zip-cat", "./cmd/gitlab-zip-cat"),
            ("gitlab-zip-metadata", "./cmd/gitlab-zip-metadata"),
            ("gitlab-resize-image", "./cmd/gitlab-resize-image"),
        ],
        '"$out/bin/gitlab-workhorse" -version',
        "gitlab-workhorse",
        "workhorse",
    ),
}

