WORKHORSE_RUNTIME_APKS = [
    ("busybox", "1.37.0-r20", "main", {"x86_64": "7cc34c2dda2520b456ab4a55abc37fe245ac90f98ab9f1c7a9be3aec035df48e", "aarch64": "9d25af67564c92a4a4c603462efdbcd23019e90b8785f1ebcad640cbb1551c93"}),
