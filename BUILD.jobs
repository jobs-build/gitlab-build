# Bundler gem-platform per build platform (the musl variants the hermetic
# build can install; "ruby" = the platform-less pure/source gems).
GEM_PLATFORM = {"linux/amd64": "x86_64-linux-musl", "linux/arm64": "aarch64-linux-musl"}

# Gems with heavyweight native extensions that publish -linux-musl variants
# (verified on rubygems.org at the locked versions). GitLab's lock carries no
# musl platform rows, so the bundler plugin's row filter only emits their
# SOURCE variants; the recipe adds the musl .gems to vendor/cache directly
# and the (non-frozen) local install prefers them.
MUSL_PRECOMPILED = [
    "grpc", "google-protobuf", "prometheus-client-mmap", "re2", "ffi",
    "nokogiri", "gitlab-glfm-markdown", "gitlab-glaz", "gitlab_query_language",
    "pg", "sass-embedded",
]

def lock_version(lock, name):
    # The bare (platform-less) SPEC row: exactly 4-space indented
    # `    name (1.2.3)` — 6-space rows are dependency edges, and
    # platform-suffixed rows carry a "-".
    prefix = "    " + name + " ("
    for line in lock.splitlines():
        if line.startswith(prefix) and not line.startswith("      ") and line.endswith(")"):
            v = line[len(prefix):-1]
            if "-" not in v and v[:1].isdigit():
                return v
    fail("gem %s: no bare spec row in Gemfile.lock" % name)

