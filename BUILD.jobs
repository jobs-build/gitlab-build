    ("libbz2", "1.0.8-r6", "main", {"x86_64": "0c98810f9332bf1bb1b0acc64eaac4b101036689bffba9ea621416b4b3c190cd", "aarch64": "1d588037cc45108acafdbb1507e9f683019a8816fb74d9aba9b0a2dc099463c4"}),
    ("musl", "1.2.5-r12", "main", {"x86_64": "4990a5e0ba312e478f94cfe431a70efef1538004eb361c8ae424516848be45bb", "aarch64": "ac281d1e7f9e9c447c51e309317b975f48be6edaf3ab91ae73b959cf86703782"}),
    ("perl", "5.40.4-r0", "main", {"x86_64": "bb6e25b2a8f34852a90ebd066e99e21722486add8272eb3d625783baec9f0654", "aarch64": "a99a05088b8ab15ef95048cf894cd209983bc2b7564ea6e3f0b69e8666c6124b"}),
    ("perl-image-exiftool", "13.30-r0", "community", {"x86_64": "f272b87cc8c372458a7abec5d588a7fffea099ff91045893b3f0562b3f9d7f99", "aarch64": "282552cc635d432e72e5c73f6da73cc696665d06a6902347881181bea1f2322c"}),
    ("zlib", "1.3.2-r0", "main", {"x86_64": "1f3d5f463f490dad3a68097376711bfe5e8156e9e8daff3070513aa4378cdeca", "aarch64": "7a39a917e4dab3c7a45537210ee5b5f17bf75f5e7777809a20cddd0afe074187"}),
